{
  "name": "no-sheet-ona-lib",
  "version": "0.1.0",
  "description": "A programmatic computation engine library. Computations are defined in code — not as string expressions or spreadsheet-style formulas.",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "module",
  "module": "dist/noSheet.esm.js",
  "browser": "dist/noSheet.umd.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:tsc": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf dist",
    "build": "rollup -c",
    "dev:watch": "rollup -c -w"
  },
  "keywords": [
    "computation",
    "engine",
    "graph",
    "DAG",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "rollup": "^4.60.3",
    "tslib": "^2.8.1"
  }
}
